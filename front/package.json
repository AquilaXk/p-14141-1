{
  "name": "morethan-log",
  "version": "1.3.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/morethanmin/morethan-log.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "contracts:fetch": "node scripts/openapi/fetch-openapi.mjs",
    "contracts:generate": "openapi-typescript contracts/openapi/openapi.json -o packages/shared-contracts/src/generated/backend-openapi.d.ts",
    "contracts:update": "yarn contracts:fetch && yarn contracts:generate",
    "contracts:verify-live": "yarn contracts:fetch && yarn contracts:check",
    "contracts:check": "node scripts/openapi/check-contract-drift.mjs",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:e2e:smoke": "env -u NO_COLOR playwright test e2e/smoke.spec.ts e2e/mobile-layout.spec.ts",
    "test:e2e:perf": "env -u NO_COLOR playwright test e2e/perf.spec.ts",
    "test:e2e:a11y": "env -u NO_COLOR playwright test e2e/accessibility.spec.ts",
    "test:e2e:live": "env -u NO_COLOR PLAYWRIGHT_LIVE_MULTI_BROWSER=true playwright test e2e/live.spec.ts --workers=1",
    "storybook": "HOME=$PWD/.storybook-home CI=1 STORYBOOK_DISABLE_TELEMETRY=1 STORYBOOK_DISABLE_UPDATE_CHECK=1 storybook dev -p 6006",
    "storybook:build:raw": "HOME=$PWD/.storybook-home CI=1 STORYBOOK_DISABLE_TELEMETRY=1 STORYBOOK_DISABLE_UPDATE_CHECK=1 storybook build",
    "storybook:build": "yarn storybook:build:raw",
    "storybook:gate": "node scripts/storybook/run-storybook-gate.mjs",
    "storybook:test": "HOME=$PWD/.storybook-home CI=1 STORYBOOK_DISABLE_TELEMETRY=1 STORYBOOK_DISABLE_UPDATE_CHECK=1 storybook test --watch=false",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "postbuild": "echo \"skip next-sitemap (handled by pages/sitemap.xml.tsx)\"",
    "lint": "next lint"
  },
  "dependencies": {
    "@babel/runtime": "^7.18.3",
    "@emotion/react": "^11.11.1",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@next/env": "^14.2.5",
    "@radix-ui/colors": "^1.0.0",
    "@shared/contracts": "file:packages/shared-contracts",
    "@shared/ui-tokens": "file:packages/shared-ui-tokens",
    "@shared/utils": "file:packages/shared-utils",
    "@tanstack/react-query": "^5.64.2",
    "axios": ">=0.21.1",
    "cookies-next": "^2.1.2",
    "mermaid": "^10.9.1",
    "next": "^14.2.5",
    "next-sitemap": "^3.1.32",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.0.1",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/nextjs": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@playwright/test": "^1.55.0",
    "@axe-core/playwright": "^4.10.2",
    "@types/gtag.js": "^0.0.12",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.39.0",
    "eslint-config-next": "^14.2.5",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.3.11",
    "prettier": "^2.7.1",
    "prismjs": "^1.29.0",
    "webpack": "^5.97.1",
    "storybook": "^8.6.14",
    "typescript": "^5.6.3"
  }
}
