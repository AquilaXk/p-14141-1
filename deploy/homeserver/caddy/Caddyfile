{
  email {$CADDY_EMAIL}
}

# Uptime Kuma dashboard/status endpoint (optional).
# Set MONITOR_DOMAIN in .env.prod and Cloudflare Tunnel Public Hostname.
http://{$MONITOR_DOMAIN:status.localhost} {
  reverse_proxy uptime_kuma:3001 {
    # Allow embedding public status page in admin UI.
    header_down -X-Frame-Options
    header_down -Content-Security-Policy
  }

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }
}

# Cloudflare Tunnel origin: HTTP only between cloudflared and Caddy.
http://{$API_DOMAIN} {
  log {
    output stdout
    format json
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }

  @notificationSse path /member/api/v1/notifications/stream
  handle @notificationSse {
    header {
      Cache-Control "no-cache, no-transform"
    }

    reverse_proxy back-blue:8080 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
      flush_interval -1
    }
  }

  @publicFeed {
    path /post/api/v1/posts/feed
    method GET
    not header Cookie *
  }
  @publicExplore {
    path /post/api/v1/posts/explore
    method GET
    not header Cookie *
  }
  handle @publicFeed {
    header {
      Cache-Control "public, max-age=60, stale-while-revalidate=300"
    }

    reverse_proxy back-blue:8080 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
    }
  }

  handle @publicExplore {
    header {
      Cache-Control "public, max-age=30, stale-while-revalidate=120"
    }

    reverse_proxy back-blue:8080 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
    }
  }

  # Blue/Green cutover rewrites single active upstream host.
  handle {
    encode gzip zstd

    reverse_proxy back-blue:8080 {
      # Public traffic is HTTPS at the Cloudflare edge, but the tunnel origin to
      # Caddy is plain HTTP. Spring uses forwarded headers to compute OAuth2
      # callback URLs, so we pin the upstream scheme/host to the external URL.
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
    }
  }
}
