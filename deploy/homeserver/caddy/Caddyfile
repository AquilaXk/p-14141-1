# Set PROMETHEUS_DOMAIN in .env.prod and Cloudflare Tunnel Public Hostname.
http://{$PROMETHEUS_DOMAIN:prometheus.localhost} {
  basicauth {
    {$PROMETHEUS_BASIC_AUTH_USER:promviewer} {$PROMETHEUS_BASIC_AUTH_HASH:$2y$05$g4sdUn.YYoUOjAy/41KhSOBCQvOnwTNJ/jmdl/95o8YKEoq/gddPC}
  }

  reverse_proxy prometheus:9090

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }
}

# Cloudflare Tunnel origin: HTTP only between cloudflared and Caddy.
http://{$API_DOMAIN} {
  log {
    output stdout
    format json
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }

  @notificationSse path /member/api/v1/notifications/stream
  handle @notificationSse {
    header {
      Cache-Control "no-cache, no-transform"
    }

    reverse_proxy back_blue:8080 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
      flush_interval -1
    }
  }

  # Prometheus metrics are scraped via internal Docker network only.
  # Public access via API domain is explicitly denied.
  @denyPrometheus path /actuator/prometheus
  respond @denyPrometheus 403

  @publicFeed {
    path /post/api/v1/posts/feed
    method GET HEAD OPTIONS
  }
  @publicExplore {
    path /post/api/v1/posts/explore
    method GET HEAD OPTIONS
  }
  handle @publicFeed {
    header {
      Cache-Control "public, max-age=60, stale-while-revalidate=300"
    }

    reverse_proxy {$READ_API_UPSTREAM:back_blue}:8080 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
    }
  }

  handle @publicExplore {
    header {
      Cache-Control "public, max-age=30, stale-while-revalidate=120"
    }

    reverse_proxy {$READ_API_UPSTREAM:back_blue}:8080 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
    }
  }

  # read 런타임 분리: 공개 read API를 별도 upstream으로 점진 분리할 수 있다.
  @publicReadFallback {
    path /post/api/v1/posts/search /post/api/v1/posts/tags /post/api/v1/posts/feed/cursor /post/api/v1/posts/explore/cursor /post/api/v1/posts/* /post/api/v1/posts/*/comments /post/api/v1/posts/*/comments/*
    method GET HEAD OPTIONS
  }
  handle @publicReadFallback {
    reverse_proxy {$READ_API_UPSTREAM:back_blue}:8080 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
    }
  }

  # 점진 분리: admin API는 별도 upstream으로 라우팅 가능(기본 back_blue 유지).
  @adminApi {
    path /post/api/v1/adm/* /member/api/v1/adm/* /system/api/v1/adm/*
  }
  handle @adminApi {
    reverse_proxy {$ADMIN_API_UPSTREAM:back_blue}:8080 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
    }
  }

  # Blue/Green cutover rewrites single active upstream host.
  handle {
    encode gzip zstd

    reverse_proxy back_blue:8080 {
      # Public traffic is HTTPS at the Cloudflare edge, but the tunnel origin to
      # Caddy is plain HTTP. Spring uses forwarded headers to compute OAuth2
      # callback URLs, so we pin the upstream scheme/host to the external URL.
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
    }
  }
}
