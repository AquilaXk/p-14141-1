# Domain used by Caddy
API_DOMAIN=api.example.com
MONITOR_DOMAIN=status.example.com
GRAFANA_DOMAIN=grafana.example.com
PROMETHEUS_DOMAIN=prometheus.example.com
CADDY_EMAIL=you@example.com
CF_TUNNEL_TOKEN=change_me_cloudflare_tunnel_token
BACK_IMAGE=ghcr.io/aquilaxk/aquila-blog-back:sha-<commit7>
CLOUDFLARED_IMAGE=cloudflare/cloudflared:<pin-tag-or-digest>
DB_IMAGE=jangka512/pgj:<pin-tag-or-digest>
MINIO_IMAGE=minio/minio:<pin-tag-or-digest>
# Optional Prometheus retention
# PROMETHEUS_RETENTION_TIME=15d
# Prometheus basic auth for public UI route (bcrypt hash recommended)
# username default: promviewer
# password default hash corresponds to: change_me_prom_password
PROMETHEUS_BASIC_AUTH_USER=promviewer
PROMETHEUS_BASIC_AUTH_HASH=$$2y$$05$$g4sdUn.YYoUOjAy/41KhSOBCQvOnwTNJ/jmdl/95o8YKEoq/gddPC
# Grafana bootstrap credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
GRAFANA_ROOT_URL=https://grafana.example.com
# steady-state guard: Grafana datasource auto-heal
# 연속 실패 임계치(기본 3)
# GRAFANA_DS_FAIL_THRESHOLD=3
# 재기동 쿨다운 초(기본 900초)
# GRAFANA_DS_RECREATE_COOLDOWN_SECONDS=900
# Back container auto-heal (restart unhealthy app containers)
# AUTOHEAL_INTERVAL_SECONDS=15
# AUTOHEAL_START_PERIOD_SECONDS=300
# BACK_AUTOHEAL_ENABLED=true
# NOTE: container healthcheck is liveness(/actuator/health/liveness).
# readiness(/actuator/health/readiness)는 배포 cutover 검증용으로만 사용한다.
# Back container memory guard (blue/green 동시 기동 시 OOM 방지)
# BACK_MEM_LIMIT=512m
# BACK_MEM_RESERVATION=256m
# BACK_WORKER_MEM_LIMIT=768m
# BACK_WORKER_MEM_RESERVATION=768m
# 배포 시점 자동 메모리 튜너(가드 포함, HOME_SERVER_ENV로 제어 가능)
# true면 host MemTotal 기준으로 BACK_*_MEM_{LIMIT,RESERVATION}를 자동 산출한다.
# AUTO_MEMORY_TUNER_ENABLED=true
# 전체 백엔드 컨테이너 예산 상한(MB). 기본 2816(2.8GB)
# AUTO_MEMORY_TUNER_MAX_BUDGET_MB=2816
# 호스트 시스템 예약 메모리(MB). 기본 2048
# AUTO_MEMORY_TUNER_SYSTEM_RESERVE_MB=2048
# 자동 산출 최소 예산(MB). 기본 1280 (runtime-split에서는 내부 최소 2048 가드 적용)
# AUTO_MEMORY_TUNER_MIN_BUDGET_MB=1280

# Spring production overrides
PROD___SPRING__DATASOURCE__PASSWORD=change_me_db_password
PROD___SPRING__DATA__REDIS__PASSWORD=change_me_redis_password

# Optional app-level values
CUSTOM__JWT__SECRET_KEY=change_me_very_long_secret_key_32_plus
# Admin login is email-only in production.
# CUSTOM__ADMIN__USERNAME is used as admin display nickname.
CUSTOM__ADMIN__USERNAME=관리자
CUSTOM__ADMIN__EMAIL=admin@example.com
CUSTOM__ADMIN__PASSWORD=change_me_admin_password
# Runtime role toggle (single binary split mode)
# true  -> API + background workers 함께 실행(기본)
# false -> API 전용으로 실행 (worker는 별도 프로세스/배포에서 true로 실행)
# CUSTOM__RUNTIME__WORKER_ENABLED=true
# API 모드 분리(all/read/admin). 기본은 all.
# CUSTOM__RUNTIME__API_MODE=all
# 런타임 분리 전용 profile(back_read/back_admin) 활성화 시 사용
# COMPOSE_PROFILES=runtime-split
# 배포 스크립트에서 runtime-split을 강제 활성화할 때 사용
# RUNTIME_SPLIT_ENABLED=true
# Stage A=all, Stage B=admin
# RUNTIME_SPLIT_STAGE=A
# 컨테이너별 모드 오버라이드(점진 분리 시 사용)
# CUSTOM__RUNTIME__API_MODE_BLUE=all
# CUSTOM__RUNTIME__API_MODE_GREEN=admin
# CUSTOM__RUNTIME__API_MODE_WORKER=all
# runtime-split profile에서 read/admin 전용 컨테이너 메모리
# BACK_READ_MEM_LIMIT=640m
# BACK_READ_MEM_RESERVATION=320m
# BACK_ADMIN_MEM_LIMIT=384m
# BACK_ADMIN_MEM_RESERVATION=192m
# Caddy read/admin API 전용 upstream (기본 back_blue)
# READ_API_UPSTREAM=back_read
# Caddy admin API 전용 upstream (기본 back_blue)
# ADMIN_API_UPSTREAM=back_admin
# post read prewarm / search-index async sync
# CUSTOM__POST__READ__PREWARM__ENABLED=true
# CUSTOM__POST__READ__PREWARM__PAGE_SIZE=30
# CUSTOM__POST__READ__PREWARM__MAX_TAG_WARMUPS=3
# 기본 explore(kw/tag 없음) 추천 랭킹 파이프라인
# CUSTOM__POST__RECOMMEND__ENABLED=true
# CUSTOM__POST__RECOMMEND__CANDIDATE_POOL_SIZE=240
# CUSTOM__POST__RECOMMEND__MAX_RERANK_PAGES=4
# CUSTOM__POST__RECOMMEND__HOT_TAGS_LIMIT=24
# 추천 피처 스토어(post_attr JSON + 로컬 TTL)
# CUSTOM__POST__RECOMMEND__FEATURE_STORE__ENABLED=true
# CUSTOM__POST__RECOMMEND__FEATURE_STORE__STALE_SECONDS=900
# CUSTOM__POST__RECOMMEND__FEATURE_STORE__LOCAL_CACHE_TTL_SECONDS=120
# CUSTOM__POST__SEARCH_INDEX__ASYNC_SYNC_ENABLED=true
# CUSTOM__POST__SEARCH_INDEX__MAX_TAGS=32
# CUSTOM__POST__SEARCH_INDEX__SLA__MAX_LAG_SECONDS=120
# 검색 랭킹 파이프라인(A/B + shadow-read + force rollback)
# CUSTOM__POST__SEARCH__PIPELINE__ENABLED=true
# CUSTOM__POST__SEARCH__PIPELINE__CANDIDATE_POOL_SIZE=220
# CUSTOM__POST__SEARCH__PIPELINE__MAX_RERANK_PAGES=4
# CUSTOM__POST__SEARCH__PIPELINE__ROLLBACK__FORCE_CONTROL=false
# CUSTOM__POST__SEARCH__PIPELINE__AB__ENABLED=true
# CUSTOM__POST__SEARCH__PIPELINE__AB__VARIANT_TRAFFIC_PERCENT=25
# CUSTOM__POST__SEARCH__PIPELINE__CONTROL__TITLE_WEIGHT=300
# CUSTOM__POST__SEARCH__PIPELINE__CONTROL__TAG_WEIGHT=120
# CUSTOM__POST__SEARCH__PIPELINE__CONTROL__CONTENT_WEIGHT=40
# CUSTOM__POST__SEARCH__PIPELINE__CONTROL__FRESHNESS_WEIGHT=1.0
# CUSTOM__POST__SEARCH__PIPELINE__VARIANT__TITLE_WEIGHT=260
# CUSTOM__POST__SEARCH__PIPELINE__VARIANT__TAG_WEIGHT=180
# CUSTOM__POST__SEARCH__PIPELINE__VARIANT__CONTENT_WEIGHT=70
# CUSTOM__POST__SEARCH__PIPELINE__VARIANT__FRESHNESS_WEIGHT=1.1
# CUSTOM__POST__SEARCH__PIPELINE__SHADOW_READ__ENABLED=true
# CUSTOM__POST__SEARCH__PIPELINE__SHADOW_READ__COMPARE_TOP_N=20
# CUSTOM__POST__SEARCH__PIPELINE__SHADOW_READ__WARN_DELTA_THRESHOLD=0.45
# CUSTOM__POST__SEARCH__PIPELINE__SHADOW_READ__EXTERNAL__ENABLED=false
# CUSTOM__POST__SEARCH__PIPELINE__SHADOW_READ__EXTERNAL__ENDPOINT=https://search-shadow.example.com/query
# CUSTOM__POST__SEARCH__PIPELINE__SHADOW_READ__EXTERNAL__API_KEY=change_me_shadow_read_api_key
# CUSTOM__POST__SEARCH__PIPELINE__SHADOW_READ__EXTERNAL__CONNECT_TIMEOUT_MS=300
# CUSTOM__POST__SEARCH__PIPELINE__SHADOW_READ__EXTERNAL__REQUEST_TIMEOUT_MS=800
# OpenSearch/ES dual-write 준비(기본 비활성)
# CUSTOM__POST__SEARCH_ENGINE__MIRROR__ENABLED=false
# CUSTOM__POST__SEARCH_ENGINE__MIRROR__ENDPOINT=https://search.example.com/index/post
# CUSTOM__POST__SEARCH_ENGINE__MIRROR__API_KEY=change_me_search_api_key
# CUSTOM__POST__SEARCH_ENGINE__MIRROR__CONNECT_TIMEOUT_MS=1200
# CUSTOM__POST__SEARCH_ENGINE__MIRROR__REQUEST_TIMEOUT_MS=2500
# CUSTOM__POST__SEARCH_ENGINE__MIRROR__MAX_TAGS=32
# CUSTOM__POST__SEARCH_ENGINE__MIRROR__CIRCUIT__FAILURE_THRESHOLD=5
# CUSTOM__POST__SEARCH_ENGINE__MIRROR__CIRCUIT__OPEN_SECONDS=60
# Task worker 동적 백프레셔
# CUSTOM__TASK__PROCESSOR__DYNAMIC_CONCURRENCY_ENABLED=true
# CUSTOM__TASK__PROCESSOR__DYNAMIC_MIN_CONCURRENT=2
# CUSTOM__TASK__PROCESSOR__DYNAMIC_BACKLOG_PER_SLOT=25
# CUSTOM__TASK__PROCESSOR__DYNAMIC_BATCH_SIZE_ENABLED=true
# CUSTOM__TASK__PROCESSOR__DYNAMIC_BATCH_MIN_SIZE=4
# CUSTOM__TASK__PROCESSOR__DYNAMIC_BATCH_BACKLOG_PER_STEP=120
# CUSTOM__TASK__PROCESSOR__DYNAMIC_BATCH_TARGET_HANDLER_DURATION_MS=900
# CUSTOM__TASK__PROCESSOR__DYNAMIC_BATCH_MAX_PREFETCH_MULTIPLIER=2
# CUSTOM__TASK__PROCESSOR__PER_TYPE_MAX_CONCURRENT=post.search-index.sync=4,post.read.prewarm=2,post.search-engine.mirror=1
# 공개 read bulkhead 기본값(feed/explore/search/detail/tags)
# CUSTOM__POST__READ__BULKHEAD__FEED_MAX_CONCURRENT=20
# CUSTOM__POST__READ__BULKHEAD__EXPLORE_MAX_CONCURRENT=10
# CUSTOM__POST__READ__BULKHEAD__SEARCH_MAX_CONCURRENT=8
# CUSTOM__POST__READ__BULKHEAD__DETAIL_MAX_CONCURRENT=16
# CUSTOM__POST__READ__BULKHEAD__TAGS_MAX_CONCURRENT=6
# CUSTOM__TASK__PROCESSOR__PER_TYPE_AUTO_TUNE_ENABLED=true
# CUSTOM__TASK__PROCESSOR__PER_TYPE_AUTO_TUNE_MIN_CONCURRENT=1
# CUSTOM__TASK__PROCESSOR__PER_TYPE_AUTO_TUNE_BACKLOG_PER_SLOT=20
# CUSTOM__TASK__PROCESSOR__PER_TYPE_AUTO_TUNE_REFRESH_MS=15000
# Safety: prod SQL init은 비활성화(스키마 변경은 Flyway만 사용)
# SPRING_SQL_INIT_MODE=never
# Production actuator exposure (default: health only)
# MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health
# Login brute-force protection (optional overrides)
# CUSTOM__AUTH__LOGIN__MAX_ATTEMPTS=5
# CUSTOM__AUTH__LOGIN__WINDOW_SECONDS=300
# CUSTOM__AUTH__LOGIN__LOCK_SECONDS=600

# Spring custom.prod.* mapping
CUSTOM_PROD_COOKIEDOMAIN=example.com
CUSTOM_PROD_FRONTURL=https://www.example.com
CUSTOM_PROD_BACKURL=https://api.example.com
CUSTOM_PROD_DBNAME=blog_prod
CUSTOM_PROD_REDISDATABASE=0

# Front ISR on-demand revalidate webhook (optional but recommended for instant feed updates)
CUSTOM__REVALIDATE__URL=https://www.example.com/api/revalidate
CUSTOM__REVALIDATE__TOKEN=change_me_revalidate_token

# Front monitoring links (admin tools page)
# NEXT_PUBLIC_MONITORING_EMBED_URL=https://grafana.example.com/d/blog-overview/main?orgId=1&kiosk
# NEXT_PUBLIC_PROMETHEUS_URL=https://prometheus.example.com

# AI preview summary (Gemini)
CUSTOM__AI__SUMMARY__ENABLED=true
CUSTOM__AI__SUMMARY__GEMINI__API_KEY=change_me_gemini_api_key
CUSTOM__AI__SUMMARY__GEMINI__MODEL=gemini-2.5-flash

# SMTP (email verification signup)
SPRING__MAIL__HOST=smtp.example.com
SPRING__MAIL__PORT=587
SPRING__MAIL__USERNAME=mailer@example.com
SPRING__MAIL__PASSWORD=change_me_smtp_password
SPRING__MAIL__PROPERTIES__MAIL__SMTP__AUTH=true
SPRING__MAIL__PROPERTIES__MAIL__SMTP__STARTTLS__ENABLE=true
CUSTOM__MEMBER__SIGNUP__MAIL_FROM=mailer@example.com
CUSTOM__MEMBER__SIGNUP__MAIL_SUBJECT=[AquilaXk] 회원가입 이메일 인증
CUSTOM__MEMBER__SIGNUP__VERIFY_PATH=/signup/verify
CUSTOM__MEMBER__SIGNUP__EMAIL_EXPIRATION_SECONDS=86400
CUSTOM__MEMBER__SIGNUP__SESSION_EXPIRATION_SECONDS=3600

# Optional DB base name (default: blog)
# DB_BASE_NAME=blog

# MinIO (post image storage)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_minio_password
CUSTOM_STORAGE_ENABLED=true
# Must be full URI (e.g., http://minio:9000), not just `http:`
CUSTOM_STORAGE_ENDPOINT=http://minio:9000
CUSTOM_STORAGE_REGION=us-east-1
CUSTOM_STORAGE_BUCKET=blog-images
# Use concrete values (do not use ${...} placeholders here).
CUSTOM_STORAGE_ACCESSKEY=minio
CUSTOM_STORAGE_SECRETKEY=change_me_minio_password
CUSTOM_STORAGE_PATHSTYLEACCESS=true
CUSTOM_STORAGE_KEYPREFIX=posts
CUSTOM_STORAGE_MAXFILESIZEBYTES=10485760
CUSTOM__STORAGE__RETENTION__TEMP_UPLOAD_SECONDS=86400
CUSTOM__STORAGE__RETENTION__REPLACED_PROFILE_IMAGE_SECONDS=259200
CUSTOM__STORAGE__RETENTION__DELETED_POST_ATTACHMENT_SECONDS=1209600
CUSTOM__STORAGE__RETENTION__CLEANUP_FIXED_DELAY_MS=3600000
CUSTOM__STORAGE__RETENTION__CLEANUP_BATCH_SIZE=100
