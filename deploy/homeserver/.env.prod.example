# Domain used by Caddy
API_DOMAIN=api.example.com
MONITOR_DOMAIN=status.example.com
CADDY_EMAIL=you@example.com
CF_TUNNEL_TOKEN=change_me_cloudflare_tunnel_token

# Spring production overrides
PROD___SPRING__DATASOURCE__PASSWORD=change_me_db_password
PROD___SPRING__DATA__REDIS__PASSWORD=change_me_redis_password

# Optional app-level values
CUSTOM__JWT__SECRET_KEY=change_me_very_long_secret_key_32_plus
# Only this id/password account is treated as admin.
CUSTOM__ADMIN__USERNAME=aquila
CUSTOM__ADMIN__PASSWORD=change_me_admin_password
# Runtime role toggle (single binary split mode)
# true  -> API + background workers 함께 실행(기본)
# false -> API 전용으로 실행 (worker는 별도 프로세스/배포에서 true로 실행)
# CUSTOM__RUNTIME__WORKER_ENABLED=true
# Production actuator exposure (default: health only)
# MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health
# Login brute-force protection (optional overrides)
# CUSTOM__AUTH__LOGIN__MAX_ATTEMPTS=5
# CUSTOM__AUTH__LOGIN__WINDOW_SECONDS=300
# CUSTOM__AUTH__LOGIN__LOCK_SECONDS=600

# Spring custom.prod.* mapping
CUSTOM_PROD_COOKIEDOMAIN=example.com
CUSTOM_PROD_FRONTURL=https://www.example.com
CUSTOM_PROD_BACKURL=https://api.example.com
CUSTOM_PROD_DBNAME=blog_prod
CUSTOM_PROD_REDISDATABASE=0

# Front ISR on-demand revalidate webhook (optional but recommended for instant feed updates)
CUSTOM__REVALIDATE__URL=https://www.example.com/api/revalidate
CUSTOM__REVALIDATE__TOKEN=change_me_revalidate_token

# SMTP (email verification signup)
SPRING__MAIL__HOST=smtp.example.com
SPRING__MAIL__PORT=587
SPRING__MAIL__USERNAME=mailer@example.com
SPRING__MAIL__PASSWORD=change_me_smtp_password
SPRING__MAIL__PROPERTIES__MAIL__SMTP__AUTH=true
SPRING__MAIL__PROPERTIES__MAIL__SMTP__STARTTLS__ENABLE=true
CUSTOM__MEMBER__SIGNUP__MAIL_FROM=mailer@example.com
CUSTOM__MEMBER__SIGNUP__MAIL_SUBJECT=[AquilaXk] 회원가입 이메일 인증
CUSTOM__MEMBER__SIGNUP__VERIFY_PATH=/signup/verify
CUSTOM__MEMBER__SIGNUP__EMAIL_EXPIRATION_SECONDS=86400
CUSTOM__MEMBER__SIGNUP__SESSION_EXPIRATION_SECONDS=3600

# Optional DB base name (default: blog)
# DB_BASE_NAME=blog

# MinIO (post image storage)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_minio_password
CUSTOM_STORAGE_ENABLED=true
# Must be full URI (e.g., http://minio:9000), not just `http:`
CUSTOM_STORAGE_ENDPOINT=http://minio:9000
CUSTOM_STORAGE_REGION=us-east-1
CUSTOM_STORAGE_BUCKET=blog-images
# Use concrete values (do not use ${...} placeholders here).
CUSTOM_STORAGE_ACCESSKEY=minio
CUSTOM_STORAGE_SECRETKEY=change_me_minio_password
CUSTOM_STORAGE_PATHSTYLEACCESS=true
CUSTOM_STORAGE_KEYPREFIX=posts
CUSTOM_STORAGE_MAXFILESIZEBYTES=10485760
CUSTOM__STORAGE__RETENTION__TEMP_UPLOAD_SECONDS=86400
CUSTOM__STORAGE__RETENTION__REPLACED_PROFILE_IMAGE_SECONDS=259200
CUSTOM__STORAGE__RETENTION__DELETED_POST_ATTACHMENT_SECONDS=1209600
CUSTOM__STORAGE__RETENTION__CLEANUP_FIXED_DELAY_MS=3600000
CUSTOM__STORAGE__RETENTION__CLEANUP_BATCH_SIZE=100
